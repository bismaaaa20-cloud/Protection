-- GLOBAL SETTINGS (Format murni Lua - VERSI ANTI AIR LAUT DI BAWAH PULAU)
getgenv().FastEnergyRegen = true       -- Pengisian energi kilat
getgenv().AntiPlayerComboShield = true -- Desync anti-combo PvP
getgenv().ComboBreaker = true          -- Lepas dari status kaku / stun
getgenv().SuperSmallHitbox = true      -- Hitbox super kecil (0.1)
getgenv().AdaptiveDodge = true         -- Sistem menghindar pintar berdasarkan area & darah

local Player = game.Players.LocalPlayer
local LastDamageTime = 0
local ShieldActive = false
local EscapeActive = false

-- =========================================================
-- 1. LOOP: FAST REGEN ENERGY (Bisa Dash & Melompat Lancar)
-- =========================================================
task.spawn(function()
    while task.wait(0.01) do
        local Character = Player.Character
        if Character then
            local EnergyObj = Character:FindFirstChild("Energy") or Player:FindFirstChild("Data") and Player.Data:FindFirstChild("Energy")
            if getgenv().FastEnergyRegen and EnergyObj and EnergyObj:IsA("IntValue") then
                if EnergyObj.Value < EnergyObj.MaxValue then
                    EnergyObj.Value = math.min(EnergyObj.MaxValue, EnergyObj.Value + 500)
                end
            end
        end
    end
end)

-- =========================================================
-- 2. LOGIKA UTAMA PROTEKSI PVP & ANTI AIR LAUT UNDERGROUND
-- =========================================================
local function AturSistemPVP(Character)
    local Humanoid = Character:WaitForChild("Humanoid")
    local RootPart = Character:WaitForChild("HumanoidRootPart")
    local LastHealth = Humanoid.Health

    -- FIX STABILIZER LANTAI ANTI-AMBLAS
    if getgenv().SuperSmallHitbox and RootPart and Humanoid then
        RootPart.Size = Vector3.new(0.1, 0.1, 0.1)
        task.spawn(function()
            while Character and Character.Parent and getgenv().SuperSmallHitbox do
                if Humanoid.HipHeight ~= 3.5 then
                    Humanoid.HipHeight = 3.5
                end
                task.wait(0.5)
            end
        end)
    end

    Humanoid.HealthChanged:Connect(function(CurrentHealth)
        local CurrentTime = tick()
        local HealthPercentage = CurrentHealth / Humanoid.MaxHealth
        
        if getgenv().AdaptiveDodge and CurrentHealth > 0 and not EscapeActive then
            -- HANYA AKTIF JIKA DARAH DI BAWAH 60%
            if HealthPercentage < 0.60 then
                EscapeActive = true
                
                task.spawn(function()
                    -- A. PENENTUAN DURASI SEMBUNYI
                    local HoldDuration = 3.0 
                    if HealthPercentage <= 0.20 then
                        HoldDuration = 15.0 
                        print("[Smart Dodge] Darah <= 20%! Sembunyi permanen: " .. HoldDuration .. " detik.")
                    elseif HealthPercentage < 0.30 then
                        HoldDuration = 7.0
                    end
                    
                    -- B. MEMASANG ALAT GRAVITASI BYPASS
                    local BodyVelocity = Instance.new("BodyVelocity")
                    BodyVelocity.Velocity = Vector3.new(0, 0, 0)
                    BodyVelocity.MaxForce = Vector3.new(0, math.huge, 0)
                    BodyVelocity.Parent = RootPart
                    
                    -- C. DETEKSI RELEVANSI LANTAI (RAYCAST)
                    local RayParam = RaycastParams.new()
                    RayParam.FilterDescendantsInstances = {Character}
                    RayParam.FilterType = Enum.RaycastFilterType.Exclude
                    local LantaiCek = game.Workspace:Raycast(RootPart.Position, Vector3.new(0, -150, 0), RayParam)
                    
                    local IsDiAtasLaut = false
                    if not LantaiCek or (LantaiCek and LantaiCek.Instance and string.find(string.lower(LantaiCek.Instance.Name), "water")) then
                        IsDiAtasLaut = true
                    end
                    
                    -- D. EKSEKUSI DODGE BERDASARKAN LOKASI AIR VS DARAT
                    if IsDiAtasLaut then
                        -- JIKA MEMANG SEDANG DI LAUT LEPAS: Meluncur ke atas langit tinggi (Bypass air)
                        print("[Area Scan] Di laut lepas! Mengelak naik tinggi ke langit...")
                        RootPart.CFrame = RootPart.CFrame * CFrame.new(25, 0, 0)
                        task.wait(0.02)
                        for i = 1, 25 do 
                            RootPart.CFrame = RootPart.CFrame * CFrame.new(0, 9, 0)
                            task.wait(0.01)
                        end
                        task.wait(HoldDuration)
                    else
                        -- JIKA DI ATAS PULAU (Darat): Geser ke samping, amblas TIPIS di bawah lantai pulau (Anti Air Laut)
                        print("[Area Scan] Di atas pulau! Sembunyi tipis di bawah struktur lantai...")
                        RootPart.CFrame = RootPart.CFrame * CFrame.new(25, 0, 0)
                        task.wait(0.02)
                        
                        -- Menggunakan koordinat hasil deteksi permukaan lantai asli
                        local TinggiLantaiAsli = LantaiCek.Position
                        
                        -- Membuat platform pijakan gaib darurat di bawah tanah agar TIDAK JATUH KE LAUT
                        local SafePlatform = Instance.new("Part")
                        SafePlatform.Size = Vector3.new(10, 1, 10)
                        SafePlatform.Position = TinggiLantaiAsli - Vector3.new(0, 8, 0) -- Berada 8 stud di bawah lantai pulau
                        SafePlatform.Anchored = true
                        SafePlatform.Transparency = 1 -- Tidak terlihat
                        SafePlatform.Parent = game.Workspace
                        
                        -- Pindahkan posisi karakter tepat di atas platform gaib tersebut
                        RootPart.CFrame = CFrame.new(SafePlatform.Position + Vector3.new(0, 4, 0))
                        
                        task.wait(HoldDuration) -- Menahan sembunyi di dalam tanah pulau
                        
                        -- Kembalikan karakter ke atas permukaan sebelum menghapus platform
                        RootPart.CFrame = CFrame.new(TinggiLantaiAsli + Vector3.new(0, 4, 0))
                        SafePlatform:Destroy()
                    end
                    
                    -- E. PENDARATAN AKHIR AMAN ANTI-AMBLAS
                    local HasilRay = game.Workspace:Raycast(RootPart.Position, Vector3.new(0, -500, 0), RayParam)
                    if HasilRay then
                        RootPart.CFrame = CFrame.new(HasilRay.Position + Vector3.new(0, 4, 0))
                    end
                    
                    BodyVelocity:Destroy()
                    EscapeActive = false
                    print("[Smart Dodge] Selesai, kembali ke permukaan dengan aman.")
                end)
            end
        end

        -- DETEKSI HIT MASUK
        if CurrentHealth < LastHealth then
            local rawDamage = LastHealth - CurrentHealth
            
            -- ANTI ONE-SHOT / COMBO SHIELD
            if getgenv().AntiPlayerComboShield and (CurrentTime - LastDamageTime) < 1.0 then
                if not ShieldActive then
                    ShieldActive = true
                    task.spawn(function()
                        local SimpanCFrame = RootPart.CFrame
                        while ShieldActive do
                            RootPart.CFrame = SimpanCFrame * CFrame.new(0, -20, 0) 
                            task.wait()
                        end
                        RootPart.CFrame = SimpanCFrame 
                    end)
                    task.delay(1.5, function() ShieldActive = false end)
                end
            end
            
            -- ANTI-STUN PVP (Combo Breaker)
            if getgenv().ComboBreaker and (CurrentTime - LastDamageTime) < 1.2 then
                Humanoid.PlatformStand = false
                Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                if RootPart.Anchored then RootPart.Anchored = false end
            end
            
            LastDamageTime = CurrentTime
        end
        LastHealth = Humanoid.Health
    end)
end

if Player.Character then task.spawn(AturSistemPVP, Player.Character) end
Player.CharacterAdded:Connect(function(NewCharacter)
    string.clear = nil
    task.spawn(AturSistemPVP, NewCharacter)
end)
