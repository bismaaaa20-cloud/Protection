-- GLOBAL SETTINGS (Format murni Lua - UNIVERSAL DODGE BYPASS)
getgenv().FastEnergyRegen = true       -- Pengisian energi kilat (Bisa Dash & Melompat Lancar)
getgenv().AntiPlayerComboShield = true -- Desync anti-combo PvP (Hitbox pindah ke bawah tanah)
getgenv().ComboBreaker = true          -- Lepas dari status kaku / stun skill lawan
getgenv().SuperSmallHitbox = true      -- Hitbox super kecil (0.1) agar serangan musuh meleset total
getgenv().LowHealthSkyDodge = true     -- AKTIF UNIVERSAL: Mengelak ke langit dari semua NPC & Player

local Player = game.Players.LocalPlayer
local LastDamageTime = 0
local ShieldActive = false
local EscapeActive = false

-- =========================================================
-- 1. LOOP: FAST REGEN ENERGY (Bisa Dash & Melompat Lancar)
-- =========================================================
task.spawn(function()
    while task.wait(0.01) do
        local Character = Player.Character
        if Character then
            local EnergyObj = Character:FindFirstChild("Energy") or Player:FindFirstChild("Data") and Player.Data:FindFirstChild("Energy")
            if getgenv().FastEnergyRegen and EnergyObj and EnergyObj:IsA("IntValue") then
                if EnergyObj.Value < EnergyObj.MaxValue then
                    EnergyObj.Value = math.min(EnergyObj.MaxValue, EnergyObj.Value + 500)
                end
            end
        end
    end
end)

-- =========================================================
-- 2. LOGIKA UTAMA PROTEKSI UNIVERSAL & BYPASS DODGE
-- =========================================================
local function AturSistemPVP(Character)
    local Humanoid = Character:WaitForChild("Humanoid")
    local RootPart = Character:WaitForChild("HumanoidRootPart")
    local LastHealth = Humanoid.Health

    -- HITBOX SUPER KECIL + ANTI-AMBLAS
    if getgenv().SuperSmallHitbox and RootPart and Humanoid then
        RootPart.Size = Vector3.new(0.1, 0.1, 0.1)
        Humanoid.HipHeight = 2.8 
    end

    Humanoid.HealthChanged:Connect(function(CurrentHealth)
        local CurrentTime = tick()
        
        -- =========================================================
        -- PENYEMPURNAAN: FLY-ESCAPE DARI ALL PLAYER & ALL NPC
        -- =========================================================
        -- Memicu refleks menghindar universal saat darah menyentuh batas kritis di bawah 30%
        if getgenv().LowHealthSkyDodge and CurrentHealth < (Humanoid.MaxHealth * 0.3) and not EscapeActive and CurrentHealth > 0 then
            EscapeActive = true
            task.spawn(function()
                print("[Universal Dodge] Darah kritis akibat Serangan! Meluncur ke langit...")
                
                -- Memasang jangkar penahan gravitasi pasif agar tidak memicu deteksi speed-hack game
                local BodyVelocity = Instance.new("BodyVelocity")
                BodyVelocity.Velocity = Vector3.new(0, 0, 0)
                BodyVelocity.MaxForce = Vector3.new(0, math.huge, 0)
                BodyVelocity.Parent = RootPart
                
                -- Meluncur naik setinggi 120 stud secara halus (Linear bypass anti-cheat)
                for i = 1, 15 do
                    RootPart.CFrame = RootPart.CFrame * CFrame.new(0, 8, 0)
                    task.wait(0.01)
                end
                
                -- Mengunci posisi Anda di zona aman udara selama 4 detik untuk memulihkan diri
                task.wait(4.0)
                
                -- Menghapus penahan beban dan mengembalikan kontrol gravitasi normal
                BodyVelocity:Destroy()
                EscapeActive = false
                print("[Universal Dodge] Durasi habis, kembali ke medan tempur.")
            end)
        end

        -- DETEKSI HIT MASUK (DARI PLAYER MAUPUN NPC)
        if CurrentHealth < LastHealth then
            local rawDamage = LastHealth - CurrentHealth
            
            -- ANTI ONE-SHOT / COMBO SHIELD (Desync Hitbox)
            if getgenv().AntiPlayerComboShield and (CurrentTime - LastDamageTime) < 1.0 then
                if not ShieldActive then
                    ShieldActive = true
                    task.spawn(function()
                        local SimpanCFrame = RootPart.CFrame
                        while ShieldActive do
                            RootPart.CFrame = SimpanCFrame * CFrame.new(0, -20, 0) 
                            task.wait()
                        end
                        RootPart.CFrame = SimpanCFrame 
                    end)
                    task.delay(1.5, function() ShieldActive = false end)
                end
            end
            
            -- ANTI-STUN UNIVERSAL (Combo Breaker)
            if getgenv().ComboBreaker and (CurrentTime - LastDamageTime) < 1.2 then
                Humanoid.PlatformStand = false
                Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                if RootPart.Anchored then RootPart.Anchored = false end
            end
            
            LastDamageTime = CurrentTime
        end
        LastHealth = Humanoid.Health
    end)
end

-- Menjalankan skrip saat pertama kali di-inject ke Executor
if Player.Character then task.spawn(AturSistemPVP, Player.Character) end

-- Mengunci skrip otomatis jalan lagi setiap kali Anda Respawn (Hidup Lagi)
Player.CharacterAdded:Connect(function(NewCharacter)
    string.clear = nil
    task.spawn(AturSistemPVP, NewCharacter)
end)
