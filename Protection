-- GLOBAL SETTINGS (Murni Lua - Versi Aman Tanpa Modifikasi Memori)
getgenv().InstantTriggerHeal = true 
getgenv().InfiniteEnergy = true     
getgenv().ComboBreaker = true        
getgenv().SmallHitbox = true         
getgenv().DamageReduction = 0.5     

local Player = game.Players.LocalPlayer

-- REFRESH LOOP DARAH & ENERGI PASIF (Mengikuti Batas Maksimal Asli)
task.spawn(function()
	while task.wait(0.1) do -- Jeda aman agar tidak memicu desync data
		local Character = Player.Character
		local Humanoid = Character and Character:FindFirstChild("Humanoid")
		
		if Humanoid then
			-- Pemulihan darah otomatis pasif saat terluka
			if getgenv().InstantTriggerHeal and Humanoid.Health < Humanoid.MaxHealth then
				Humanoid.Health = math.min(Humanoid.MaxHealth, Humanoid.Health + (Humanoid.MaxHealth * 0.1))
			end
			
			-- Mengunci energi agar selalu penuh sesuai batas asli stats Anda (Anti-Bug Level 1)
			if getgenv().InfiniteEnergy then
				local EnergyObj = Character:FindFirstChild("Energy") or Player:FindFirstChild("Data") and Player.Data:FindFirstChild("Energy")
				if EnergyObj then
					EnergyObj.Value = EnergyObj.MaxValue -- Mengunci stabil di angka maksimal asli karakter
				end
			end
		end
	end
end)

-- LOGIKA ANTI-STUN & HITBOX
local function AktifkanSistemPerlindungan(Character)
	local Humanoid = Character:WaitForChild("Humanoid")
	local RootPart = Character:WaitForChild("HumanoidRootPart")
	local LastHealth = Humanoid.Health

	-- Mengubah hitbox ke ukuran aman agar tidak glitch ke lantai map
	if getgenv().SmallHitbox and RootPart then
		RootPart.Size = Vector3.new(1, 1, 1)
	end

	Humanoid.HealthChanged:Connect(function(CurrentHealth)
		if CurrentHealth < LastHealth then
			local rawDamage = LastHealth - CurrentHealth
			
			-- Anti-Stun / Combo Breaker dasar
			if getgenv().ComboBreaker then
				Humanoid.PlatformStand = false
				Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
				if RootPart.Anchored then RootPart.Anchored = false end
			end

			-- Pengurangan damage dasar
			if getgenv().DamageReduction and rawDamage > 0 then
				local reducedDamage = rawDamage * getgenv().DamageReduction
				Humanoid.Health = math.min(Humanoid.MaxHealth, CurrentHealth + (rawDamage - reducedDamage))
			end
		end
		LastHealth = Humanoid.Health
	end)
end

if Player.Character then task.spawn(AktifkanSistemPerlindungan, Player.Character) end
Player.CharacterAdded:Connect(function(NewCharacter)
	task.spawn(AktifkanSistemPerlindungan, NewCharacter)
end)
